<% layout("/layouts/boilerplate") -%>

<style>
  body {
    background: linear-gradient(135deg, #0f172a, #1e293b, #312e81);
  }

  .bookings-container {
    min-height: 100vh;
    padding: 50px 15px;
  }

  .bookings-title {
    text-align: center;
    color: white;
    font-weight: 800;
    margin-bottom: 35px;
    animation: fadeDown 0.8s ease;
  }

  .booking-card {
    border: none;
    border-radius: 26px;
    overflow: hidden;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    animation: fadeUp 0.9s ease;
    transition: 0.35s ease;
  }

  .booking-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 28px 60px rgba(0,0,0,0.45);
  }

  .booking-header {
    padding: 20px;
    color: white;
    background: linear-gradient(45deg, #7c3aed, #ec4899, #06b6d4);
    background-size: 300% 300%;
    animation: gradientMove 5s infinite ease;
  }

  .booking-body {
    padding: 24px;
  }

  .booking-info {
    background: #f8fafc;
    padding: 12px 15px;
    border-radius: 14px;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .cancel-btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 40px;
    font-weight: 800;
    color: white;
    background: linear-gradient(45deg, #ef4444, #ec4899, #f97316);
    background-size: 300% 300%;
    animation: gradientMove 5s infinite ease;
    position: relative;
    overflow: hidden;
    transition: 0.3s ease;
  }

  .cancel-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 15px 35px rgba(239,68,68,0.45);
  }

  .empty-box {
    max-width: 500px;
    margin: auto;
    padding: 35px;
    border-radius: 26px;
    text-align: center;
    color: white;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(18px);
    animation: fadeUp 0.9s ease;
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(45px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-35px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="bookings-container">
  <h2 class="bookings-title">🏨 My Bookings</h2>

  <% if (bookings.length === 0) { %>
    <div class="empty-box">
      <h3>No bookings found 😔</h3>
      <p>Book your first luxury stay with TripNEST.</p>
    </div>
  <% } %>

  <div class="container">
    <div class="row">
      <% bookings.forEach(booking => { %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="booking-card">

            <div class="booking-header">
              <h4 class="mb-1">
                <%= booking.listing ? booking.listing.title : "Deleted Listing" %>
              </h4>
              <small>
                📍 <%= booking.listing ? booking.listing.location : "Location unavailable" %>
              </small>
            </div>

            <div class="booking-body">

              <div class="booking-info">
                📅 Check In:
                <%= booking.checkIn ? booking.checkIn.toDateString() : "N/A" %>
              </div>

              <div class="booking-info">
                🏁 Check Out:
                <%= booking.checkOut ? booking.checkOut.toDateString() : "N/A" %>
              </div>

              <div class="booking-info">
                🚪 Room No: <%= booking.roomNumber || "N/A" %>
              </div>

              <div class="booking-info">
                👥 Guests: <%= booking.guests || 0 %>
              </div>

              <div class="booking-info">
                🧒 Children: <%= booking.children || 0 %>
              </div>

              <div class="booking-info">
                💳 Payment: <%= booking.paymentMethod || "N/A" %>
              </div>

              <div class="booking-info">
                💰 Total Price: ₹ <%= booking.finalPrice || 0 %>
              </div>

              <% if (booking.notes) { %>
                <div class="booking-info">
                  📝 Notes: <%= booking.notes %>
                </div>
              <% } %>

              <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST">
                <button class="cancel-btn">
                  ❌ Cancel Booking
                </button>
              </form>

            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>