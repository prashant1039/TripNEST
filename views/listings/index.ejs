<% layout("/layouts/boilerplate") -%>

<style>
/* ================= FILTER BAR ================= */

.filters-wrapper {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 0;
  border-bottom: 1px solid #eee;
}

.filters-scroll {
  display: flex;
  gap: 2.2rem;
  overflow-x: auto;
  scrollbar-width: none;
  flex: 1;
}

.filters-scroll::-webkit-scrollbar {
  display: none;
}

.filter {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
  min-width: 72px;
  text-decoration: none;
  color: #717171;
  font-size: 0.75rem;
  opacity: 0.85;
}

.filter i {
  font-size: 1.2rem;
}

.filter:hover {
  color: #000;
  opacity: 1;
}

.filter.active {
  color: #000;
  opacity: 1;
  border-bottom: 2px solid #000;
  padding-bottom: 0.5rem;
}

/* ================= FILTER BUTTON ================= */

.filter-btn {
  display: none;
  align-items: center;
  gap: 0.4rem;
  border: 1px solid #ddd;
  border-radius: 999px;
  padding: 0.45rem 0.9rem;
  background: #fff;
  font-size: 0.8rem;
  cursor: pointer;
}

/* ================= TAX PILL ================= */

.tax-pill {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  border: 1px solid #ddd;
  border-radius: 999px;
  padding: 0.45rem 0.75rem;
  white-space: nowrap;
  font-size: 0.8rem;
  background: #fff;
}

.switch {
  position: relative;
  width: 36px;
  height: 20px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  inset: 0;
  background-color: #ccc;
  border-radius: 999px;
  transition: 0.3s;
}

.slider::before {
  content: "";
  position: absolute;
  height: 14px;
  width: 14px;
  left: 3px;
  bottom: 3px;
  background-color: #fff;
  border-radius: 50%;
  transition: 0.3s;
}

.switch input:checked + .slider {
  background-color: #000;
}

.switch input:checked + .slider::before {
  transform: translateX(16px);
}

/* ================= LISTING CARDS ================= */

.listing-link {
  text-decoration: none;
  color: inherit;
}

.listing-card {
  border: none;
  border-radius: 22px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  transition: 0.3s ease;
  height: 100%;
}

.listing-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.16);
}

.listing-img-box {
  position: relative;
  height: 230px;
  overflow: hidden;
  background: #f1f5f9;
}

.listing-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: 0.4s ease;
}

.listing-card:hover .listing-img {
  transform: scale(1.08);
}

.wishlist-btn {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.92);
  color: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 18px rgba(0,0,0,0.18);
  transition: 0.3s;
  z-index: 2;
}

.wishlist-btn:hover {
  transform: scale(1.1);
  background: #fff;
}

.category-badge {
  position: absolute;
  left: 14px;
  bottom: 14px;
  background: rgba(15,23,42,0.82);
  color: white;
  padding: 6px 12px;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  backdrop-filter: blur(8px);
}

.listing-body {
  padding: 16px 18px 18px;
}

.listing-title {
  font-size: 1.05rem;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 6px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.listing-location {
  color: #64748b;
  font-size: 0.9rem;
  margin-bottom: 12px;
}

.listing-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 1rem;
  font-weight: 800;
  color: #111827;
  margin: 0;
}

.price span {
  font-weight: 500;
  color: #64748b;
  font-size: 0.85rem;
}

.view-pill {
  background: linear-gradient(135deg, #6366f1, #ec4899);
  color: white;
  padding: 7px 13px;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 700;
}

/* ================= MOBILE ================= */

@media (max-width: 768px) {
  .filters-scroll {
    display: none;
  }

  .filter-btn {
    display: inline-flex !important;
  }

  .tax-pill {
    font-size: 0.72rem;
    padding: 0.4rem 0.6rem;
  }

  .listing-img-box {
    height: 220px;
  }
}
</style>

<!-- ================= FILTER BAR ================= -->

<div class="filters-wrapper">

  <div class="filters-scroll">
    <a href="/listings" class="filter" data-category="All">
      <i class="fa-solid fa-border-all"></i>
      <span>All</span>
    </a>

    <a href="/listings?category=Trending" class="filter" data-category="Trending">
      <i class="fa-solid fa-fire"></i>
      <span>Trending</span>
    </a>

    <a href="/listings?category=Room" class="filter" data-category="Room">
      <i class="fa-solid fa-bed"></i>
      <span>Rooms</span>
    </a>

    <a href="/listings?category=Iconic Cities" class="filter" data-category="Iconic Cities">
      <i class="fa-solid fa-city"></i>
      <span>Iconic Cities</span>
    </a>

    <a href="/listings?category=Castles" class="filter" data-category="Castles">
      <i class="fa-solid fa-chess-rook"></i>
      <span>Castles</span>
    </a>

    <a href="/listings?category=Amazing Pools" class="filter" data-category="Amazing Pools">
      <i class="fa-solid fa-person-swimming"></i>
      <span>Pools</span>
    </a>

    <a href="/listings?category=Camping" class="filter" data-category="Camping">
      <i class="fa-solid fa-campground"></i>
      <span>Camping</span>
    </a>

    <a href="/listings?category=Farm" class="filter" data-category="Farm">
      <i class="fa-solid fa-tractor"></i>
      <span>Farms</span>
    </a>

    <a href="/listings?category=Arctic" class="filter" data-category="Arctic">
      <i class="fa-solid fa-snowflake"></i>
      <span>Arctic</span>
    </a>
  </div>

  <button id="filterBtn" class="filter-btn" data-bs-toggle="offcanvas" data-bs-target="#mobileFilters">
    <i class="fa-solid fa-sliders"></i> Filters
  </button>

  <div class="tax-pill">
    <span>Display total after taxes</span>
    <label class="switch">
      <input type="checkbox" id="taxSwitch">
      <span class="slider"></span>
    </label>
  </div>

</div>

<!-- ================= LISTINGS ================= -->

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-4">

  <% for (let listing of alllistings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">

        <div class="listing-card">

          <div class="listing-img-box">
            <img
              src="<%= (listing.image && listing.image.length > 0) 
                      ? listing.image[0].url 
                      : 'https://via.placeholder.com/500x350' %>"
              class="listing-img"
              alt="<%= listing.title %>"
            >

            <button class="wishlist-btn" type="button" onclick="event.preventDefault();">
              <i class="fa-solid fa-heart"></i>
            </button>

            <div class="category-badge">
              <%= listing.category || "TripNest" %>
            </div>
          </div>

          <div class="listing-body">
            <h5 class="listing-title"><%= listing.title %></h5>

            <p class="listing-location">
              <i class="fa-solid fa-location-dot me-1"></i>
              <%= listing.location %><%= listing.country ? ", " + listing.country : "" %>
            </p>

            <div class="listing-bottom">
              <p class="price" data-base-price="<%= listing.price %>">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
                <span>/ night</span>
              </p>

              <span class="view-pill">View</span>
            </div>
          </div>

        </div>

      </a>
    </div>
  <% } %>

</div>

<!-- ================= SCRIPT ================= -->

<script>
const taxSwitch = document.getElementById("taxSwitch");
const prices = document.querySelectorAll(".price");
const TAX_RATE = 0.18;

if (taxSwitch) {
  taxSwitch.addEventListener("change", () => {
    prices.forEach(p => {
      const base = Number(p.dataset.basePrice);

      p.innerHTML = taxSwitch.checked
        ? `₹ ${(base + base * TAX_RATE).toLocaleString("en-IN")} <span>(incl. tax)</span>`
        : `₹ ${base.toLocaleString("en-IN")} <span>/ night</span>`;
    });
  });
}

const filters = document.querySelectorAll(".filter");
const saved = localStorage.getItem("activeCategory");

filters.forEach(filter => {
  if (filter.dataset.category === saved) {
    filter.classList.add("active");
  }

  filter.addEventListener("click", () => {
    localStorage.setItem("activeCategory", filter.dataset.category);
  });
});

const filtersScroll = document.querySelector(".filters-scroll");
const filterBtn = document.getElementById("filterBtn");

function checkFilterOverflow() {
  if (!filtersScroll || !filterBtn) return;

  const isOverflowing =
    filtersScroll.scrollWidth > filtersScroll.clientWidth;

  if (isOverflowing || window.innerWidth <= 768) {
    filterBtn.style.display = "inline-flex";
  } else {
    filterBtn.style.display = "none";
  }
}

window.addEventListener("load", checkFilterOverflow);
window.addEventListener("resize", checkFilterOverflow);
</script>