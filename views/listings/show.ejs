<% layout("/layouts/boilerplate") -%>

<style>
  #map {
    height: 400px;
    width: 100%;
    border-radius: 12px;
  }
</style>

<!-- ✅ Mapbox token (ADDED) -->
<script>
  const mapToken = "<%= mapToken %>";
</script>

<div class="container mt-4">

  <!-- ================= LISTING DETAILS ================= -->

  <h3 class="mb-1"><%= listing.title %></h3>

  <p class="text-muted">
    Hosted by <strong><%= listing.owner.username %></strong>
  </p>

  <!-- IMAGE -->
  <% if (listing.image && listing.image.url) { %>
    <div class="mb-4">
      <img 
        src="<%= listing.image.url %>" 
        class="img-fluid w-100 rounded shadow"
        style="height: 450px; object-fit: cover;"
        alt="Listing Image"
      >
    </div>
  <% } else { %>
    <p class="text-muted">No image available</p>
  <% } %>

  <!-- DETAILS -->
  <ul class="list-group mb-3 shadow-sm">
    <li class="list-group-item"><strong>Description:</strong> <%= listing.description %></li>
    <li class="list-group-item">
      <strong>Price:</strong> ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
    </li>
    <li class="list-group-item"><strong>Location:</strong> <%= listing.location %></li>
    <li class="list-group-item"><strong>Country:</strong> <%= listing.country %></li>
  </ul>

  <!-- OWNER ACTIONS -->
  <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning me-2">Edit</a>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
      <button class="btn btn-danger">Delete</button>
    </form>
  <% } %>

  <hr class="my-4">

  <!-- ================= ADD REVIEW ================= -->

  <% if (currentUser) { %>
    <h4>Add a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="mb-4">

      <div class="mb-3">
        <label class="form-label">Your Review</label>
        <textarea 
          name="review[comment]" 
          class="form-control" 
          rows="3" 
          required
        ></textarea>
      </div>

      <fieldset class="starability-basic starability-slot">
        <legend>Rating</legend>

        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked />

        <% for (let i = 1; i <= 5; i++) { %>
          <input type="radio" id="rate<%= i %>" name="review[rating]" value="<%= i %>" />
          <label for="rate<%= i %>"><%= i %> star</label>
        <% } %>
      </fieldset>

      <button class="btn btn-success mt-3">Submit Review</button>
    </form>
  <% } else { %>
    <p class="text-muted">
      <a href="/login">Login</a> to add a review.
    </p>
  <% } %>

  <hr class="my-4">

  <!-- ================= ALL REVIEWS ================= -->

  <h4 class="mb-3">All Reviews</h4>

  <% if (listing.reviews.length === 0) { %>
    <p class="text-muted">No reviews yet.</p>
  <% } else { %>
    <div class="row">
      <% for (let review of listing.reviews) { %>
        <div class="col-md-4 col-sm-6 mb-3">
          <div class="card shadow-sm h-100">
            <div class="card-body">

              <div class="starability-result mb-2" data-rating="<%= review.rating %>">
                Rated <%= review.rating %> stars
              </div>

              <p class="mb-1 text-muted">
                <strong><%= review.author.username %></strong>
              </p>

              <p class="card-text"><%= review.comment %></p>

              <% if (currentUser && review.author._id.equals(currentUser._id)) { %>
                <form 
                  method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                >
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              <% } %>

            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- ================= MAP ================= -->

  <hr class="my-4">

  <div class="mb-4">
    <h3 class="fw-bold">WHERE YOU’LL BE</h3>
    <div id="map" class="mt-3"></div>
  </div>

</div>

<!-- ================= MAPBOX (ONLY ADDITION BELOW) ================= -->

<link
  href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css"
  rel="stylesheet"
/>
<script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>

<script>
  const listing = <%- JSON.stringify(listing) %>;
</script>

<script src="/js/map.js"></script>
