<% layout("/layouts/boilerplate") -%>

<style>
  #map {
    height: 400px;
    width: 100%;
    border-radius: 12px;
  }

  /* ================= IMAGE CONTAINER ================= */

  .image-container {
    width: 100%;
    height: 500px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background: #f5f5f5;
  }

  /* 🔥 BLUR BACKGROUND FIX */
  .image-container::before {
    content: "";
    position: absolute;
    inset: 0;

    background-image: var(--bg);
    background-size: cover;
    background-position: center;

    filter: blur(25px);
    transform: scale(1.2);
    z-index: 0;
    opacity: 0.6;
  }

  /* MAIN IMAGE */
  .listing-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;

    position: relative;
    z-index: 1;

    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }

  @media (max-width: 768px) {
    .image-container {
      height: 300px;
    }
  }
</style>

<script>
  const mapToken = "<%= mapToken %>";
</script>

<div class="container mt-4">

  <!-- ================= TITLE ================= -->

  <h3 class="mb-1"><%= listing.title %></h3>

  <p class="text-muted">
    Hosted by <strong><%= listing.owner.username %></strong>
  </p>

  <!-- ================= IMAGE ================= -->

  <% if (listing.image && listing.image.length > 0) { %>

    <div class="image-container" 
         style="--bg:url('<%= listing.image[0].url %>')">

      <img 
        src="<%= listing.image[0].url %>" 
        class="listing-img"
      >

    </div>

  <% } else { %>
    <p class="text-muted">No image available</p>
  <% } %>

  <!-- ================= DETAILS ================= -->

  <ul class="list-group mb-3 shadow-sm mt-4">
    <li class="list-group-item"><strong>Description:</strong> <%= listing.description %></li>
    <li class="list-group-item">
      <strong>Price:</strong> ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
    </li>
    <li class="list-group-item"><strong>Location:</strong> <%= listing.location %></li>
    <li class="list-group-item"><strong>Country:</strong> <%= listing.country %></li>
  </ul>

  <!-- ================= OWNER ================= -->

  <% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning me-2">Edit</a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
      <button class="btn btn-danger">Delete</button>
    </form>
  <% } %>

  <hr class="my-4">

  <!-- ================= REVIEW FORM ================= -->

  <% if (currentUser) { %>
    <h4>Add a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="mb-4">

      <textarea name="review[comment]" class="form-control mb-2" required></textarea>

      <button class="btn btn-success">Submit</button>
    </form>
  <% } %>

  <!-- ================= REVIEWS ================= -->

  <h4>All Reviews</h4>

  <% listing.reviews.forEach(review => { %>
    <div class="card mb-2">
      <div class="card-body">
        <strong><%= review.author.username %></strong>
        <p><%= review.comment %></p>
      </div>
    </div>
  <% }) %>

  <!-- ================= MAP ================= -->

  <hr class="my-4">

  <h4>Where you'll be</h4>
  <div id="map"></div>

</div>

<!-- ================= MAP ================= -->

<link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet"/>
<script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>

<script>
  const listing = <%- JSON.stringify(listing) %>;
</script>

<script src="/js/map.js"></script>