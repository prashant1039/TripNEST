<% layout("/layouts/boilerplate") -%>

<style>
  body { background: linear-gradient(135deg, #0f172a, #1e293b); }

  .booking-container {
    min-height: 100vh;
    padding: 40px 15px;
  }

  .booking-card {
    max-width: 780px;
    margin: auto;
    background: rgba(255,255,255,0.96);
    padding: 35px;
    border-radius: 28px;
    box-shadow: 0 20px 45px rgba(0,0,0,0.35);
  }

  .booking-title {
    text-align: center;
    font-weight: 800;
    color: #2d3436;
  }

  .booking-subtitle {
    text-align: center;
    color: #636e72;
    margin-bottom: 20px;
  }

  .hotel-price {
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    color: #10ac84;
    margin-bottom: 25px;
  }

  .form-label {
    font-weight: 700;
  }

  .form-control {
    border-radius: 14px;
    padding: 14px;
    border: 2px solid #dfe6e9;
  }

  .room-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(135px, 1fr));
    gap: 14px;
    margin-top: 10px;
  }

  .room-card {
    padding: 18px 10px;
    border-radius: 18px;
    text-align: center;
    cursor: pointer;
    background: linear-gradient(135deg, #ecfdf5, #d1fae5);
    border: 2px solid #10b981;
    transition: 0.3s ease;
    font-weight: 700;
  }

  .room-card:hover {
    transform: translateY(-6px) scale(1.04);
    box-shadow: 0 14px 28px rgba(16,185,129,0.35);
  }

  .room-card.selected {
    background: linear-gradient(135deg, #6366f1, #ec4899);
    color: white;
    border-color: #6366f1;
    box-shadow: 0 15px 35px rgba(99,102,241,0.4);
  }

  .summary-box {
    background: #f8fafc;
    border-radius: 18px;
    padding: 18px;
    margin: 20px 0;
    border: 1px solid #e5e7eb;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    margin: 8px 0;
    font-weight: 600;
  }

  .animated-btn {
    width: 100%;
    padding: 16px;
    font-size: 18px;
    font-weight: bold;
    border: none;
    border-radius: 40px;
    cursor: pointer;
    color: white;
    background: linear-gradient(45deg, #1dd1a1, #10ac84, #00d2d3);
    background-size: 300% 300%;
    animation: gradientMove 5s ease infinite;
    transition: 0.3s ease;
  }

  .animated-btn:hover {
    transform: scale(1.04);
  }

  textarea.form-control {
    resize: none;
    min-height: 120px;
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<div class="booking-container">
  <div class="booking-card">

    <h2 class="booking-title">🏨 Book Your Luxury Stay</h2>
    <p class="booking-subtitle"><%= listing.title %></p>

    <div class="hotel-price">
      ₹ <%= listing.price %> / Night
    </div>

    <form action="/listings/<%= listing._id %>/book" method="POST" id="bookingForm">

      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input type="text" name="booking[name]" class="form-control" required placeholder="Enter your full name">
      </div>

      <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <input type="tel" name="booking[phone]" class="form-control" required placeholder="Enter phone number">
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Check In</label>
          <input type="date" name="booking[checkIn]" id="checkIn" class="form-control" required>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Check Out</label>
          <input type="date" name="booking[checkOut]" id="checkOut" class="form-control" required>
        </div>
      </div>

      <input type="hidden" name="booking[roomNumber]" id="selectedRoom" required>
      <input type="hidden" name="booking[finalPrice]" id="finalPrice" required>

      <div class="mb-3">
        <label class="form-label">Choose Your Room</label>

        <div class="room-grid">
          <% allRooms.forEach(room => { %>
            <div
              class="room-card"
              data-room="<%= room.number %>"
              data-price="<%= room.price %>"
              data-type="<%= room.type %>"
            >
              <h5>Room <%= room.number %></h5>
              <span><%= room.type %></span><br>
              <small>₹ <%= room.price %> / night</small>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Guests</label>
          <input type="number" name="booking[guests]" min="1" class="form-control" required placeholder="Guests">
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Children</label>
          <input type="number" name="booking[children]" min="0" value="0" class="form-control" placeholder="Children">
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Payment Method</label>
        <select name="booking[paymentMethod]" class="form-control" required>
          <option value="">Select Payment Method</option>
          <option value="UPI">UPI</option>
          <option value="Cash">Cash</option>
          <option value="Card">Credit / Debit Card</option>
        </select>
      </div>

      <div class="mb-4">
        <label class="form-label">Special Requests</label>
        <textarea name="booking[notes]" class="form-control" placeholder="Any special request?"></textarea>
      </div>

      <div class="summary-box">
        <h5>Booking Summary</h5>
        <div class="summary-line"><span>Room</span><span id="summaryRoom">Not selected</span></div>
        <div class="summary-line"><span>Type</span><span id="summaryType">-</span></div>
        <div class="summary-line"><span>Nights</span><span id="summaryNights">0</span></div>
        <div class="summary-line"><span>Total</span><span>₹ <span id="summaryPrice">0</span></span></div>
      </div>

      <button class="animated-btn">
        ✨ Confirm Luxury Booking
      </button>

    </form>
  </div>
</div>

<script>
  const roomCards = document.querySelectorAll(".room-card");
  const selectedRoom = document.getElementById("selectedRoom");
  const finalPrice = document.getElementById("finalPrice");

  const checkIn = document.getElementById("checkIn");
  const checkOut = document.getElementById("checkOut");

  const summaryRoom = document.getElementById("summaryRoom");
  const summaryType = document.getElementById("summaryType");
  const summaryNights = document.getElementById("summaryNights");
  const summaryPrice = document.getElementById("summaryPrice");

  let selectedRoomPrice = 0;

  function calculateTotal() {
    if (!checkIn.value || !checkOut.value || !selectedRoomPrice) return;

    const inDate = new Date(checkIn.value);
    const outDate = new Date(checkOut.value);

    const nights = Math.ceil((outDate - inDate) / (1000 * 60 * 60 * 24));

    if (nights <= 0) {
      summaryNights.innerText = "0";
      summaryPrice.innerText = "0";
      finalPrice.value = "";
      return;
    }

    const total = nights * selectedRoomPrice;

    summaryNights.innerText = nights;
    summaryPrice.innerText = total;
    finalPrice.value = total;
  }

  roomCards.forEach(card => {
    card.addEventListener("click", () => {
      roomCards.forEach(c => c.classList.remove("selected"));

      card.classList.add("selected");

      selectedRoom.value = card.dataset.room;
      selectedRoomPrice = Number(card.dataset.price);

      summaryRoom.innerText = "Room " + card.dataset.room;
      summaryType.innerText = card.dataset.type;

      calculateTotal();
    });
  });

  checkIn.addEventListener("change", calculateTotal);
  checkOut.addEventListener("change", calculateTotal);
</script>