<% layout("/layouts/boilerplate") -%>

<style>
  body {
    background: linear-gradient(135deg, #0f172a, #1e293b);
    overflow-x: hidden;
  }

  .booking-container {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px 15px;
    position: relative;
  }

  .bg-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255,215,0,0.15), transparent 70%);
    animation: floatGlow 6s ease-in-out infinite alternate;
    z-index: 1;
  }

  .booking-card {
    width: 100%;
    max-width: 650px;
    background: rgba(255,255,255,0.95);
    padding: 35px;
    border-radius: 28px;
    box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    animation: fadeUp 1s ease;
    position: relative;
    z-index: 10;
  }

  .booking-title {
    text-align: center;
    font-weight: 700;
    color: #2d3436;
  }

  .booking-subtitle {
    text-align: center;
    color: #636e72;
    margin-bottom: 25px;
  }

  .hotel-price {
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    color: #10ac84;
    margin-bottom: 25px;
  }

  .form-label {
    font-weight: 600;
    color: #2d3436;
  }

  .form-control {
    border-radius: 14px;
    padding: 14px;
    border: 2px solid #dfe6e9;
  }

  .form-control:focus {
    border-color: #6c5ce7;
    box-shadow: 0 0 15px rgba(108,92,231,0.2);
    transform: scale(1.02);
  }

  .animated-btn {
    width: 100%;
    padding: 16px;
    font-size: 18px;
    font-weight: bold;
    border: none;
    border-radius: 40px;
    cursor: pointer;
    color: white;
    background: linear-gradient(45deg, #1dd1a1, #10ac84, #00d2d3);
    background-size: 300% 300%;
    animation: gradientMove 5s ease infinite;
  }

  .animated-btn:hover {
    transform: scale(1.04);
  }

  textarea.form-control {
    resize: none;
    min-height: 120px;
  }

  @keyframes floatGlow {
    0% { transform: translateY(-20px); }
    100% { transform: translateY(20px); }
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(50px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div class="booking-container">
  <div class="bg-glow"></div>

  <div class="booking-card">
    <h2 class="booking-title">🏨 Book Your Luxury Stay</h2>
    <p class="booking-subtitle"><%= listing.title %></p>

    <div class="hotel-price">
      ₹ <%= listing.price %> / Night
    </div>

    <form action="/listings/<%= listing._id %>/book" method="POST">

      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input type="text" name="booking[name]" class="form-control" required placeholder="Enter your full name">
      </div>

      <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <input type="tel" name="booking[phone]" class="form-control" required placeholder="Enter phone number">
      </div>

      <div class="mb-3">
        <label class="form-label">Select Date</label>
        <input type="date" name="booking[date]" class="form-control" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Room Number</label>
        <input
          type="number"
          name="booking[roomNumber]"
          min="1"
          class="form-control"
          required
          placeholder="Enter room number"
        >
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Guests</label>
          <input type="number" name="booking[guests]" min="1" class="form-control" required placeholder="Guests">
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Children</label>
          <input type="number" name="booking[children]" min="0" value="0" class="form-control" placeholder="Children">
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Payment Method</label>
        <select name="booking[paymentMethod]" class="form-control" required>
          <option value="">Select Payment Method</option>
          <option value="UPI">UPI</option>
          <option value="Cash">Cash</option>
          <option value="Card">Credit / Debit Card</option>
        </select>
      </div>

      <div class="mb-4">
        <label class="form-label">Special Requests</label>
        <textarea name="booking[notes]" class="form-control" placeholder="Any special request?"></textarea>
      </div>

      <button class="animated-btn">
        ✨ Confirm Luxury Booking
      </button>

    </form>
  </div>
</div>