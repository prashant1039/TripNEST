<style>
  .navbar {
    backdrop-filter: blur(14px);
    background: rgba(255, 255, 255, 0.92) !important;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    font-family: "Plus Jakarta Sans", sans-serif;
    padding: 0.8rem 1rem;
  }

  /* ANIMATED LOGO */
  .navbar-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 1.5rem;
    font-weight: 800;
    text-decoration: none;
  }

  .tripnest-logo {
    width: 58px;
    height: 58px;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hotel-core {
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, #6366f1, #ec4899, #f59e0b);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 20px;
    box-shadow: 0 0 20px rgba(99,102,241,0.45);
    animation: pulseGlow 2s infinite ease-in-out;
    z-index: 2;
  }

  .orbit {
    position: absolute;
    width: 58px;
    height: 58px;
    border: 2px dashed rgba(99,102,241,0.35);
    border-radius: 50%;
    animation: rotateOrbit 6s linear infinite;
  }

  .orbit::before {
    content: "✈️";
    position: absolute;
    top: -10px;
    left: 18px;
    font-size: 18px;
  }

  .brand-text {
    font-size: 30px;
    font-weight: 900;
    background: linear-gradient(45deg, #6366f1, #ec4899, #f59e0b);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientMove 4s ease infinite;
  }

  .nav-link {
    font-weight: 600;
    color: #334155 !important;
    transition: 0.3s;
    position: relative;
  }

  .nav-link:hover {
    color: #6366f1 !important;
    transform: translateY(-2px);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, #6366f1, #ec4899);
    transition: 0.3s;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .search-form {
    position: relative;
    width: 340px;
  }

  .search-inp {
    border-radius: 999px;
    padding: 0.7rem 3.2rem 0.7rem 1.3rem;
    border: 1px solid #e5e7eb;
    background: #f8fafc;
    transition: 0.3s;
  }

  .search-inp:focus {
    background: white;
    border-color: #6366f1;
    box-shadow: 0 0 0 4px rgba(99,102,241,0.15);
  }

  .search-btn {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    border: none;
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    color: white;
    background: linear-gradient(135deg, #6366f1, #ec4899);
  }

  .search-dropdown {
    position: absolute;
    top: 115%;
    width: 100%;
    background: white;
    border-radius: 16px;
    box-shadow: 0 16px 40px rgba(0,0,0,0.15);
    display: none;
    z-index: 1000;
    max-height: 250px;
    overflow-y: auto;
    padding: 8px;
  }

  .search-dropdown.active {
    display: block;
  }

  .search-item {
    padding: 0.8rem 1rem;
    cursor: pointer;
    border-radius: 12px;
    transition: 0.2s;
  }

  .search-item:hover {
    background: #f1f5f9;
    color: #4f46e5;
  }

  @keyframes rotateOrbit {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes pulseGlow {
    0%,100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.12);
    }
  }

  @keyframes gradientMove {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @media (max-width: 768px) {
    .search-form {
      width: 100%;
      margin: 0.8rem 0;
    }
  }
</style>

<nav class="navbar navbar-expand-md sticky-top border-bottom">
  <div class="container-fluid">

    <!-- ANIMATED LOGO -->
    <a class="navbar-brand" href="/listings">
      <div class="tripnest-logo">
        <div class="orbit"></div>
        <div class="hotel-core">🏨</div>
      </div>
      <span class="brand-text">TripNEST</span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <div class="navbar-nav ms-auto me-3">
        <form class="search-form" id="searchForm" action="/listings" method="GET">

          <input
            class="form-control search-inp"
            id="searchInput"
            name="q"
            type="search"
            placeholder="Search destinations..."
            autocomplete="off"
            value="<%= typeof q !== 'undefined' ? q : '' %>"
          >

          <button class="search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>

          <div class="search-dropdown" id="searchDropdown">
            <div class="search-item">Delhi</div>
            <div class="search-item">Mumbai</div>
            <div class="search-item">Goa</div>
            <div class="search-item">Manali</div>
            <div class="search-item">Jaipur</div>
            <div class="search-item">Udaipur</div>
          </div>

        </form>
      </div>

      <div class="navbar-nav">

        <a class="nav-link" href="/listings/new">
          TripNest your Home
        </a>

        <% if(!currentUser) { %>
          <a class="nav-link" href="/signup">Signup</a>
          <a class="nav-link" href="/login">Login</a>
        <% } %>

        <% if(currentUser) { %>
          <a class="nav-link" href="/bookings">My Bookings</a>
          <a class="nav-link" href="/logout">Logout</a>
        <% } %>

      </div>

    </div>
  </div>
</nav>

<script>
  const input = document.getElementById("searchInput");
  const dropdown = document.getElementById("searchDropdown");
  const items = document.querySelectorAll(".search-item");

  if (input) {
    input.addEventListener("focus", () => {
      dropdown.classList.add("active");
    });

    input.addEventListener("input", () => {
      dropdown.classList.add("active");

      const filter = input.value.toLowerCase();

      items.forEach(item => {
        const text = item.innerText.toLowerCase();
        item.style.display = text.includes(filter) ? "block" : "none";
      });
    });

    items.forEach(item => {
      item.addEventListener("click", () => {
        const value = item.innerText;
        window.location.href = `/listings?q=${encodeURIComponent(value)}`;
      });
    });

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".search-form")) {
        dropdown.classList.remove("active");
      }
    });
  }
</script>